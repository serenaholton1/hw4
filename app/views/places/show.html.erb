<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="h2 mb-0 cute-title"><%= @place&.name %></h1>
    <p class="mb-0 cute-subtitle">Tiny moments, big memories.</p>
  </div>
  <% if @current_user != nil %>
    <a href="/entries/new?place_id=<%= @place&.id %>" class="btn btn-success">Add New Entry</a>
  <% end %>
</div>

<h2 class="h4 mb-3 cute-title">My Entries</h2>

<% if @entries.any? %>
  <div class="row g-3">
    <% @entries.each do |entry| %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm entry-card-hover">
          <div class="card-body">
            <h3 class="h5 card-title"><%= entry.title %></h3>
            <p class="text-muted mb-2"><%= entry.occurred_on %></p>
            <p class="card-text mb-0"><%= entry.description %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">No entries yet. Add your first memory.</p>
<% end %>
