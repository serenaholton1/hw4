<h1><%= @place["name"] %></h1>

<h2>My Entries</h2>
<div class="row g-3 mb-3">
  <% for entry in @entries %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <h3 class="h5 card-title"><%= entry["title"] %></h3>
          <h4 class="h6 text-muted"><%= entry["occurred_on"] %></h4>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @entries.empty? %>
  <p>No entries yet.</p>
<% end %>

<p>
  <% if @current_user != nil %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-success">New Entry</a>
  <% end %>
</p>

<p>
  <a href="/places" class="btn btn-outline-secondary">Back to All Places</a>
</p>
