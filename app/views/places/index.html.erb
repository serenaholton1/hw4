<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h2 mb-0">Places</h1>
  <a href="/places/new" class="btn btn-success">Add New Place</a>
</div>

<% if @places.any? %>
  <div class="list-group">
    <% @places.each do |place| %>
      <a href="/places/<%= place.id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
        <span><%= place.name %></span>
        <span class="badge text-bg-light">View</span>
      </a>
    <% end %>
  </div>
<% else %>
  <p class="text-muted mb-0">No places yet. Add your first one.</p>
<% end %>
