<div class="entry-card">
  <h1>New Place</h1>
  <p class="entry-subtitle">Name a place you want to remember.</p>

  <%= form_with url: "/places", method: :post, scope: nil, local: true do |form| %>
    <div class="field">
      <%= form.label :name, "Name", for: "name_input" %>
      <%= form.text_field :name, id: "name_input" %>
    </div>

    <%= form.submit "Create place" %>
  <% end %>
</div>
