<div class="card border-0 shadow-sm">
  <div class="card-body">
    <h1 class="h3 cute-title">New Place</h1>
    <p class="cute-subtitle">Add somewhere special to your journal.</p>

    <%= form_with url: "/places", method: :post, scope: nil, local: true do |form| %>
      <div class="mb-3">
        <%= form.label :name, "Name", for: "name_input", class: "form-label" %>
        <%= form.text_field :name, id: "name_input", class: "form-control", required: true %>
      </div>

      <%= form.submit "Create place", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
