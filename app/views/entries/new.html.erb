<div class="card border-0 shadow-sm">
  <div class="card-body">
    <h1 class="h3">New Entry</h1>

    <%= form_with url: "/entries", method: :post, scope: nil, local: true do |form| %>
      <%= form.hidden_field :place_id, value: params["place_id"] %>

      <div class="mb-3">
        <%= form.label :title, "Title", for: "title_input", class: "form-label" %>
        <%= form.text_field :title, id: "title_input", class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= form.label :occurred_on, "Occurred On", for: "occurred_on_input", class: "form-label" %>
        <%= form.date_field :occurred_on, id: "occurred_on_input", class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= form.label :description, "Description", for: "description_input", class: "form-label" %>
        <%= form.text_area :description, id: "description_input", class: "form-control", rows: 5, required: true %>
      </div>

      <%= form.submit "Create entry", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
