<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Tacostagram Final</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg bg-light border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/places">Places Journal</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#main-navbar" aria-controls="main-navbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="main-navbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="/places">Home</a>
            </li>
          </ul>

          <ul class="navbar-nav mb-2 mb-lg-0 align-items-lg-center">
            <% if @current_user == nil %>
              <li class="nav-item me-lg-2 mb-2 mb-lg-0">
                <a href="/login" class="btn btn-outline-primary">Login</a>
              </li>
              <li class="nav-item">
                <a href="/users/new" class="btn btn-primary">Signup</a>
              </li>
            <% else %>
              <li class="nav-item navbar-text me-lg-3">
                Logged in as: <strong><%= @current_user["username"] %></strong>
              </li>
              <li class="nav-item">
                <a href="/logout" class="btn btn-outline-danger">Logout</a>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container py-4">
      <% if flash["notice"] != nil %>
        <div class="alert alert-info"><%= flash["notice"] %></div>
      <% end %>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
