<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Places Journal</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <%= stylesheet_link_tag "application" %>

    <style>
      @import url("https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Nunito:wght@400;500;700&display=swap");

      :root {
        --rose: #ff6f91;
        --peach: #ff9671;
        --mint: #27c9a8;
        --ink: #2c2a33;
      }

      body {
        font-family: "Nunito", system-ui, sans-serif;
        background: radial-gradient(1200px 600px at 10% -10%, #b7d3ff 0%, transparent 60%),
                    radial-gradient(900px 500px at 90% 10%, #ffd6e3 0%, transparent 55%),
                    linear-gradient(180deg, #f7f7fb 0%, #f3f7ff 100%);
        min-height: 100vh;
        color: var(--ink);
      }

      .journal-navbar {
        background: #fffffff0;
        backdrop-filter: blur(6px);
        box-shadow: 0 6px 22px rgba(45, 42, 56, 0.08);
      }

      .navbar-brand {
        font-family: "Fraunces", serif;
        letter-spacing: -0.01em;
      }

      .nav-link {
        font-weight: 700;
      }

      .page-shell {
        background: #fffffff0;
        border: 1px solid rgba(31, 31, 36, 0.08);
        border-radius: 24px;
        box-shadow: 0 22px 44px rgba(46, 43, 57, 0.11);
      }

      .cute-title {
        font-family: "Fraunces", serif;
        letter-spacing: -0.02em;
      }

      .cute-subtitle {
        color: #6a627b;
      }

      .card {
        border-radius: 18px;
      }

      .list-group-item {
        border-radius: 14px !important;
        border: 1px solid rgba(46, 43, 57, 0.08);
      }

      .btn {
        border-radius: 999px;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      .btn-primary {
        background: linear-gradient(135deg, var(--rose), var(--peach));
        border-color: transparent;
      }

      .btn-primary:hover,
      .btn-primary:focus {
        background: linear-gradient(135deg, #ff5f86, #ff8b67);
        border-color: transparent;
      }

      .btn-success {
        background: linear-gradient(135deg, var(--mint), #6de6ce);
        border-color: transparent;
        color: #143b34;
      }

      .btn-success:hover,
      .btn-success:focus {
        background: linear-gradient(135deg, #21b596, #5cd7c0);
        border-color: transparent;
        color: #143b34;
      }

      .btn-outline-primary {
        border-color: #ff6f91;
        color: #ff4d78;
      }

      .btn-outline-danger {
        border-color: #ff8e8e;
        color: #d34c4c;
      }

      .form-control {
        border-radius: 14px;
        border-color: rgba(46, 43, 57, 0.13);
      }

      .form-control:focus {
        border-color: #ff93b2;
        box-shadow: 0 0 0 0.2rem rgba(255, 111, 145, 0.18);
      }

      .entry-card-hover {
        transition: transform 150ms ease, box-shadow 150ms ease;
      }

      .entry-card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 16px 28px rgba(46, 43, 57, 0.12) !important;
      }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg journal-navbar border-bottom mb-4">
      <div class="container">
        <a class="navbar-brand fw-semibold" href="/places">Places Journal</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#main-navbar" aria-controls="main-navbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="main-navbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="/places">Home</a>
            </li>
          </ul>

          <div class="d-flex gap-2 align-items-center">
            <% if @current_user == nil %>
              <a href="/login" class="btn btn-outline-primary btn-sm">Login</a>
              <a href="/users/new" class="btn btn-primary btn-sm">Signup</a>
            <% else %>
              <span class="navbar-text me-2">Logged in as: <strong><%= @current_user["username"] %></strong></span>
              <a href="/logout" class="btn btn-outline-danger btn-sm">Logout</a>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <div class="container">
      <div class="page-shell p-4">
        <% if flash["notice"] != nil %>
          <div class="alert alert-info"><%= flash["notice"] %></div>
        <% end %>

        <%= yield %>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
