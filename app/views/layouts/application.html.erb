<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Places Journal</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <%= stylesheet_link_tag "application" %>

    <style>
      body {
        background: radial-gradient(1200px 600px at 10% -10%, #b7d3ff 0%, transparent 60%),
                    radial-gradient(900px 500px at 90% 10%, #ffd6e3 0%, transparent 55%),
                    linear-gradient(180deg, #f7f7fb 0%, #f3f7ff 100%);
        min-height: 100vh;
      }

      .journal-navbar {
        background: #ffffffcc;
        backdrop-filter: blur(6px);
      }

      .page-shell {
        background: #ffffffcc;
        border: 1px solid rgba(31, 31, 36, 0.08);
        border-radius: 16px;
      }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg journal-navbar border-bottom mb-4">
      <div class="container">
        <a class="navbar-brand fw-semibold" href="/places">Places Journal</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#main-navbar" aria-controls="main-navbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="main-navbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="/places">Home</a>
            </li>
          </ul>

          <div class="d-flex gap-2 align-items-center">
            <% if @current_user == nil %>
              <a href="/login" class="btn btn-outline-primary btn-sm">Login</a>
              <a href="/users/new" class="btn btn-primary btn-sm">Signup</a>
            <% else %>
              <span class="navbar-text me-2">Logged in as: <strong><%= @current_user["username"] %></strong></span>
              <a href="/logout" class="btn btn-outline-danger btn-sm">Logout</a>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <div class="container">
      <div class="page-shell p-4">
        <% if flash["notice"] != nil %>
          <div class="alert alert-info"><%= flash["notice"] %></div>
        <% end %>

        <%= yield %>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
